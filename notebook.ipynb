   "source": [
    "def visualiser(stock):\n",
    "    for k, v in stock.items():\n",
    "        print(f\"Produit : {k} - Quantité : {v} \")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1cac6473",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fabriquer(prod, quantity):\n",
    "    stock.update({prod: quantity})"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b0cefcd3",
   "metadata": {},
   "outputs": [],
   "source": [
    "stock = {\n",
    "    \"pains au chocolat\": 500,\n",
    "    \"croissants\": 400,\n",
    "    \"baguettes\": 500,\n",
    "    \"beignets\": 200\n",
    "}\n",
    "\n",
    "fabriquer(\"chouquettes\", 200)\n",
    "visualiser(stock)"
   ]
  }
 ],
